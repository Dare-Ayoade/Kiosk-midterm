  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Fun Facts about Black Holes\n\u25CF The event horizon is the point of
    no return ,cross it and escape velocity exceeds light speed.\n\u25CF Time dilates
    near a black hole, clocks tick slower the closer you get \n\u25CF Hawking radiation:
    black holes slowly evaporate over trillions of years by emitting quantum particles.\n\u25CF
    Stellar-mass black holes weigh 5\u2013100 solar masses; supermassive ones can
    reach 66 billion solar masses.\n\u25CF The first image of a black hole (M87*)
    was captured by the Event Horizon Telescope in 2019.\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
