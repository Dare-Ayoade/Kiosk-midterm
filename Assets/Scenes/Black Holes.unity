  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "A black hole is a region of spacetime where gravity is so extreme that
    nothing \u2014 not even light \u2014 can escape once it\ncrosses the event horizon.
    They form when massive stars collapse at the end of their lives, compressing
    into an\ninfinitely dense singularity. Supermassive black holes, millions to
    billions of times the mass of our Sun, sit at the\ncentres of most large galaxies,
    including our own Milky Way (Sagittarius A*)."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
