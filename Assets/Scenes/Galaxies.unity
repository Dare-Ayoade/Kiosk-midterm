  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Fun Facts about Galaxies\n\u25CF The Andromeda Galaxy (M31) is on a collision
    course with the Milky Way \u2014 merger in ~4.5 billion years.\n\u25CF The observable
    universe contains roughly 2 trillion galaxies \u2014 more than grains of sand
    on all Earth's beaches.\n\u25CF Our Sun is about 26,000 light-years from the
    Milky Way's centre, in the Orion Arm.\n\u25CF The largest known galaxy, IC 1101,
    is about 6 million light-years across \u2014 60\xD7 the size of the Milky Way.\n\u25CF
    Galaxies are mostly empty space \u2014 stars within them are separated by enormous
    distances.\n\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
