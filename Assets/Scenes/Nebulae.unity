  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Fun Facts about Nebulas\n\u25CF The Orion Nebula (M42) is visible to the
    naked eye as the 'middle star' in Orion's sword.\n\u25CF The Pillars of Creation
    inside the Eagle Nebula are 4\u20135 light-years tall taller than the distance
    to our nearest star.\n\u25CF Planetary nebulae have nothing to do with planets,
    the name is historical confusion from early telescopes.\n\u25CF Nebulae are colour-coded
    by element: hydrogen glows red, oxygen blue-green, sulfur orange.\n\u25CF The
    Crab Nebula is the remnant of a supernova explosion witnessed by Chinese astronomers
    in 1054 CE.\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
